        "@types/lodash": "^4.17.24",
        "axios": "^1.15.2",
        "bcryptjs": "^2.4.3",
        "dotenv": "^17.4.2",
        "jose": "^6.2.3",
        "lodash": "^4.18.1",
        "next": "16.2.4",
        "react": "19.2.4",
        "react-dom": "19.2.4",
